# ╔══════════════════════════════════════════════════════════════════════╗
# ║  AI Code Review Agent — Environment Configuration                   ║
# ╚══════════════════════════════════════════════════════════════════════╝
#
# Quick start:
#   1. Copy this file:  cp .env.example .env
#   2. Set ONE LLM provider below (or leave all blank for demo-only mode)
#   3. Run:  docker compose up
#

# === LLM Provider ===
# Choose: "openrouter" (default), "groq", "gemini", "openai", or "anthropic"
# Auto-detects from available keys if the selected provider has no key set.
LLM_PROVIDER=openrouter

# --- Option A: OpenRouter (FREE — recommended for deployment) ---
# Get a free key at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here
# OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# --- Option B: Groq (FREE — fast inference) ---
# Get a free key at https://console.groq.com/keys
# GROQ_API_KEY=your_groq_api_key_here
# GROQ_MODEL=llama-3.3-70b-versatile

# --- Option C: Gemini (free tier at https://aistudio.google.com/apikey) ---
# GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_MODEL=gemini-2.0-flash

# --- Option C: Gemini via Vertex AI (uses Application Default Credentials) ---
# GCP_PROJECT_ID=your_gcp_project_id
# GCP_REGION=us-central1

# --- Option D: OpenAI (https://platform.openai.com/api-keys) ---
# OPENAI_API_KEY=sk-your_openai_api_key_here
# OPENAI_MODEL=gpt-4o-mini

# --- Option E: Anthropic (https://console.anthropic.com/settings/keys) ---
# ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key_here
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# === GitHub (optional — only needed for private repos or posting PR comments) ===
# GITHUB_TOKEN=your_github_pat_here
# GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# === Database (CHANGE PASSWORD FOR PRODUCTION!) ===
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/code_review
DATABASE_URL_SYNC=postgresql://postgres:postgres@postgres:5432/code_review
REDIS_URL=redis://redis:6379/0
DEBUG=false
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]
